{
  "entities": {
    "Admin": {
      "title": "Admin User",
      "description": "Administrator account with CMS access",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["superadmin", "editor"] }
      },
      "required": ["userId", "email"]
    },
    "Product": {
      "title": "Stroller Product",
      "description": "Structured product data for stroller database",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "archived"] },
        "price": { "type": "number" },
        "weight": { "type": "number" },
        "compliance": { "type": "array", "items": { "type": "string" } },
        "zh": { "type": "object" },
        "en": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["id", "brand", "status"]
    },
    "Evaluation": {
      "title": "Evaluation Report",
      "description": "5D scientific review and radar scores",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "status": { "type": "string" },
        "version": { "type": "string" },
        "scores": { "type": "object" },
        "zh": { "type": "object" },
        "en": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["id", "productId", "scores"]
    },
    "Guide": {
      "title": "Buying Guide",
      "description": "Long-form guides with risk cards and SEO",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "status": { "type": "string" },
        "riskCards": { "type": "array" },
        "seo": { "type": "object" },
        "zh": { "type": "object" },
        "en": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["id", "status"]
    },
    "News": {
      "title": "Global News",
      "description": "Industry trends and policy alerts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string" },
        "seo": { "type": "object" },
        "zh": { "type": "object" },
        "en": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["id", "category"]
    },
    "Settings": {
      "title": "CMS Settings",
      "description": "Global config and homepage slots",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "hero": { "type": "object" },
        "homeSlots": { "type": "array" }
      },
      "required": ["id"]
    },
    "User": {
      "title": "User Profile",
      "description": "Basic user profile document",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["userId", "email"]
    },
    "ChildProfile": {
      "title": "Child Profile",
      "description": "Child's physical metrics for recommendation matching",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "age": { "type": "number" },
        "height": { "type": "number" },
        "inseam": { "type": "number" },
        "weight": { "type": "number" },
        "experience": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
        "updatedAt": { "type": "object" }
      },
      "required": ["userId", "age", "height", "weight"]
    },
    "Bookmark": {
      "title": "User Bookmark",
      "description": "Bookmark reference of a product added by a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["productId", "userId"]
    }
  },
  "firestore": {
    "/admins/{userId}": { "schema": "Admin", "description": "Admin access control list" },
    "/products/{productId}": { "schema": "Product", "description": "Stroller product catalog" },
    "/evaluations/{evalId}": { "schema": "Evaluation", "description": "Evaluation reports" },
    "/guides/{guideId}": { "schema": "Guide", "description": "Buying guides" },
    "/news/{newsId}": { "schema": "News", "description": "Press releases and news" },
    "/settings/{settingId}": { "schema": "Settings", "description": "Global application configuration" },
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/users/{userId}/childProfile": { "schema": "ChildProfile", "description": "Child physical profile for matching" },
    "/users/{userId}/bookmarks/{productId}": { "schema": "Bookmark", "description": "User saved products bookmarks collection" }
  }
}
