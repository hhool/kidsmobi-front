{
  "name": "kidsmobi",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "node dist/server.cjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "import:generate": "node scripts/generate_products_import_from_backend.mjs",
    "import:cms": "node scripts/cms_import_full_from_backend_v2.mjs",
    "import:cms:init": "node scripts/cms_import_full_from_backend_v2.mjs --sourceBase=https://kidsmobi-api-v1.seaman-player.workers.dev --cmsBase=https://kidsmobi-api-v1.seaman-player.workers.dev --perCategory=12 --manifestPath=./tmp/front_image_transfer_manifest.init.json",
    "import:cms:init:stage": "npm run -s import:cms:init && npm run -s media:stage:local",
    "specs:stage:product": "node scripts/product_stage_specs_from_backend_v2.mjs",
    "specs:stage:product:init": "node scripts/product_stage_specs_from_backend_v2.mjs --sourceBase=https://kidsmobi-api-v1.seaman-player.workers.dev --outputRoot=./resource/assets/backend-import --perCategory=12",
    "media:stage:local": "node scripts/media_stage_images_local.mjs --manifestPath=./tmp/front_image_transfer_manifest.init.json --stagingRoot=./resource/assets/backend-import --outputManifest=./tmp/front_image_transfer_manifest.staged.json --skipExisting",
    "media:stage:local:cpk": "node scripts/media_stage_images_local.mjs --manifestPath=./tmp/front_image_transfer_manifest.init.json --stagingRoot=./resource/assets/backend-import --outputManifest=./tmp/front_image_transfer_manifest.staged.cpk.json --pathMode=category-product-kind --skipExisting",
    "media:transfer:r2": "node scripts/media_transfer_images_to_r2.mjs",
    "media:transfer:r2:staged": "node scripts/media_transfer_images_to_r2.mjs --manifestPath=./tmp/front_image_transfer_manifest.staged.json --preferLocal --localOnly --skipExisting --concurrency=3",
    "media:transfer:r2:staged:cpk": "node scripts/media_transfer_images_to_r2.mjs --manifestPath=./tmp/front_image_transfer_manifest.staged.cpk.json --preferLocal --localOnly --skipExisting --concurrency=3",
    "cms:smoke": "node scripts/smoke_cms_d1_endpoints.mjs",
    "cms:regress": "node scripts/regress_cms_d1_crud.mjs",
    "cms:replace:safe": "node scripts/cms_safe_replace_from_export.mjs",
    "cms:reset:a": "node scripts/reset_cms_d1_a_scope.mjs",
    "perf:sample": "node scripts/sample_web_vitals.mjs",
    "perf:sample:desktop": "node scripts/sample_web_vitals.mjs --strategy=desktop",
    "perf:trend": "node scripts/compare_web_vitals_trend.mjs",
    "perf:gate": "node scripts/compare_web_vitals_trend.mjs",
    "seo:check": "node scripts/check-seo-assets.mjs",
    "reports:normalize:check": "node scripts/normalize_reports_quality.mjs",
    "reports:normalize": "node scripts/normalize_reports_quality.mjs --write"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.14.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
