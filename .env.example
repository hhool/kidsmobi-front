# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional: switch the frontend content loader to the scraped bundle proxy.
# Use "scraped" to load /api/content/bundle, or leave unset to keep CMS fallback.
VITE_CONTENT_SOURCE="cms"

# Optional: upstream kidsmobi worker base URL used by /api/content/bundle.
# The server aggregates /api/v1/catalog/categories, /api/v1/products, /api/v1/resources, and /api/v1/discovery/home from this host.
SCRAPE_KIDSMOBILE_API_BASE_URL="https://kidsmobi-api-v1.seaman-player.workers.dev"

# Optional: backend API base URL used by admin CMS resource picker.
# When set, picker prefers `${VITE_CMS_BACKEND_BASE_URL}/api/content/resources`
# and falls back to worker aggregation if backend endpoint is unavailable.
VITE_CMS_BACKEND_BASE_URL=""

# Optional: dedicated API base URL for CMS D1 endpoints (`/api/cms/*`).
# D1 client base URL precedence:
# 1) VITE_CMS_API_BASE_URL
# 2) VITE_CMS_BACKEND_BASE_URL
# 3) relative `/api/cms/*` on current origin
VITE_CMS_API_BASE_URL=""

# Optional: Cloudflare D1 HTTP API configuration used by CMS endpoints.
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_D1_DATABASE_ID=""
CLOUDFLARE_API_TOKEN=""
