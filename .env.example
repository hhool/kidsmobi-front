# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ---------------------------------------------------------------------------
# Cloudflare R2 Object Storage (optional — required for asset uploads)
# See doc/Cloudflare-R2-Public-Access.md for setup instructions.
# ---------------------------------------------------------------------------

# Cloudflare account ID (visible in the Cloudflare dashboard URL)
R2_ACCOUNT_ID="MY_R2_ACCOUNT_ID"

# R2 API token credentials (create via R2 → Manage R2 API Tokens)
R2_ACCESS_KEY_ID="MY_R2_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY="MY_R2_SECRET_ACCESS_KEY"

# R2 bucket name
R2_BUCKET_NAME="MY_R2_BUCKET_NAME"

# Public URL prefix for the bucket (set once you enable public access).
# Format: https://<bucket>.<accountId>.r2.dev  OR  https://cdn.example.com
# Leave empty to use the server-side proxy for previews (/api/assets/fetch).
R2_PUBLIC_URL=""
