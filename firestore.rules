rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isPublished() {
      return resource.data.status == "published";
    }

    // Admin List
    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      // Allow the superadmin to bootstrap their own admin document
      allow write: if isSignedIn() && request.auth.uid == userId && request.auth.token.email == "hhool.student@gmail.com";
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Evaluations
    match /evaluations/{evalId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Guides
    match /guides/{guideId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // News
    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users and User Bookmarks
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) 
        && request.resource.data.userId == userId 
        && request.resource.data.email is string 
        && request.resource.data.email.size() <= 200;
      allow delete: if isOwner(userId);

      match /bookmarks/{productId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId) 
          && request.resource.data.userId == userId 
          && request.resource.data.productId == productId 
          && (request.resource.data.createdAt == request.time || request.resource.data.createdAt == null);
        allow delete: if isOwner(userId);
      }
    }
  }
}
