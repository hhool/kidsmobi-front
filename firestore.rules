rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "hhool.student@gmail.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isPublished() {
      return resource.data.status == "published";
    }

    // Admin List
    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      // Allow the superadmin to bootstrap their own admin document
      allow write: if isSignedIn() && request.auth.uid == userId && request.auth.token.email == "hhool.student@gmail.com";
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Evaluations
    match /evaluations/{evalId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Guides
    match /guides/{guideId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // News
    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users & Bookmarks
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /childProfile/{id} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /bookmarks/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
  }
}
